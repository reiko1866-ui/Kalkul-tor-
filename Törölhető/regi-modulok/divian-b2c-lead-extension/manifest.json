{
  "manifest_version": 3,
  "name": "Divian lakossági lead (item-lists)",
  "description": "Otthoni/vevői gép: item-lists → csak cikkszám / megnevezés / mennyiség + vevő adatok, központi szerverre. A belső „teljes” forwardert ne telepítsd ugyanarra a profilra.",
  "version": "1.0.0",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "tabs", "debugger"],
  "host_permissions": ["<all_urls>", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
