# Divian központi szerver — másold: config/szerver.local.env és szerkeszd.
# Windows: DIVIAN_DATA_ROOT=C:\DivianSzerver\data

DIVIAN_SERVER_MODE=1

# Hálózat (0.0.0.0 = minden interfész; nginx mögött: 127.0.0.1 is elég)
DIVIAN_BIND_HOST=0.0.0.0
DIVIAN_STATIC_PORT=17321

# Központi adatmappa (Windows C: meghajtó)
DIVIAN_DATA_ROOT=C:\DivianSzerver\data

# Nyilvános URL (https + domain, perjel nélkül) — böngésző API hívásokhoz
# Példa: https://megrendelo.divian.hu
DIVIAN_PUBLIC_URL=

# Adatmappák (Linux Docker: /var/divian/data)
# DIVIAN_DATA_ROOT=/var/divian/data

# F: tükör — szerveren általában kikapcsolva; SMB útvonal ha kell:
# DIVIAN_ORDER_MIRROR_DIR=\\fajl-szerver\Automata megrendelők 2026
DIVIAN_ORDER_MIRROR_OFF=1

# Böngésző automatikus nyitás szerveren: ne
DIVIAN_OPEN_BROWSER=0

# Számlázz: helyi PDF előnézet (1) vagy éles API (0 + agent kulcs)
SZAMLAZZ_LOCAL_ONLY=1
SZAMLAZZ_USE_MARDOHOME_SELLER=1

# Playwright PDF (mentés) — Dockerben: DIVIAN_PLAYWRIGHT_NO_CHANNEL=1
DIVIAN_PLAYWRIGHT_NO_CHANNEL=1

# Auth — NE kapcsolod ki élesben
# DIVIAN_AUTH_OFF=0

# Új fiók hozzáadás (tunnel / távolról): oszd meg a csapattal
# DIVIAN_ACCOUNT_SETUP_KEY=valtoztasd-meg-erős-kulcsra
# DIVIAN_ADMIN_EMAILS=vaciut@divian.hu,divian@vaciut.hu
