# Divian központi szerver — config/szerver.local.env felülírhatja.



DIVIAN_SERVER_MODE=1



DIVIAN_BIND_HOST=0.0.0.0

DIVIAN_STATIC_PORT=17321



# Központi adatok (Windows)

DIVIAN_DATA_ROOT=C:\DivianSzerver\data



DIVIAN_PUBLIC_URL=



DIVIAN_ORDER_MIRROR_OFF=1

# DIVIAN_ORDER_MIRROR_DIR=\\fajl-szerver\Automata megrendelők 2026



DIVIAN_OPEN_BROWSER=0

SZAMLAZZ_LOCAL_ONLY=1

SZAMLAZZ_USE_MARDOHOME_SELLER=1

DIVIAN_PLAYWRIGHT_NO_CHANNEL=1



# Új fiók regisztráció (csapat-kulcs — oszd meg a kollégákkal)

DIVIAN_ACCOUNT_SETUP_KEY=Divian_Csapat_2026

